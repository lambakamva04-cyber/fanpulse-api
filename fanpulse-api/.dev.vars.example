# ─────────────────────────────────────────────────────────────
# Local development secrets for Cloudflare Worker
# 1. Copy this file: cp .dev.vars.example .dev.vars
# 2. Fill in your real values in .dev.vars
# 3. Run: npm run dev
#
# .dev.vars is gitignored — never commit real values.
#
# For production, set secrets via:
#   npx wrangler secret put SUPABASE_URL
#   npx wrangler secret put SUPABASE_SERVICE_KEY
#   ... etc
# ─────────────────────────────────────────────────────────────

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
JWT_SECRET=your_jwt_secret_min_32_chars_here
RAPIDAPI_FOOTBALL_KEY=your_rapidapi_key_here
SPORTSDB_API_KEY=your_thesportsdb_key_here
YOUTUBE_API_KEY=your_youtube_data_api_key_here
NEWS_API_KEY=your_newsapi_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
