{
    "modifiers": ["ctrl", "shift", "alt"],
    "actions": [
        { "key": "ctrl+",                       "action": "fineTweak" },
        { "key": "ctrl+",                       "action": "editorSelect" },
        { "key": "ctrl+s",                      "action": "saveProject" },
        { "key": "ctrl+z",                      "action": "undo" },
        { "key": "shift+ctrl+z",                "action": "redo" },
        { "key": "space",                       "action": "play" },
        { "key": "ctrl+left",                   "action": "rewind" },
        { "key": "alt+r",                       "action": "armRecord" },
        { "key": "f8",                          "action": "showMainBrowser" },
        { "key": "f10",                         "action": "showMainSettings" },
        { "key": "f6",                          "action": "showRack" },
        { "key": "f9",                          "action": "showMainMixer" },
        { "key": "shift+ctrl+t",                "action": "showTempo" },
        { "key": "ctrl+k",                      "action": "showTransport" },
        { "key": "ctrl+c",                      "action": "copy" },
        { "key": "ctrl+v",                      "action": "paste" },
        { "key": "ctrl+x",                      "action": "cut" },
        { "key": "ctrl+a",                      "action": "selectAll" },
        { "key": "delete",                      "action": "delete" },
        { "key": "ctrl+up",                     "action": "leaveFolder" },
        { "key": "ctrl+=",                      "action": "increment" },
        { "key": "shift+ctrl+=",                "action": "fineIncrement" },
        { "key": "ctrl+-",                      "action": "decrement" },
        { "key": "shift+ctrl+-",                "action": "fineDecrement" },
        { "key": "ctrl+=",                      "action": "zoomInHorizontal" },
        { "key": "shift+ctrl+=",                "action": "zoomInVertical" },
        { "key": "ctrl+-",                      "action": "zoomOutHorizontal" },
        { "key": "shift+ctrl+-",                "action": "zoomOutVertical" },
        { "key": "escape",                      "action": "close" },
        { "key": "enter",                       "action": "open" },
        { "key": "tab",                         "action": "focusNext" },
        { "key": "shift+tab",                   "action": "focusPrev" },
        { "key": "right",                       "action": "focusRight" },
        { "key": "left",                        "action": "focusLeft" },
        { "key": "up",                          "action": "focusUp" },
        { "key": "down",                        "action": "focusDown" }
    ]
}
