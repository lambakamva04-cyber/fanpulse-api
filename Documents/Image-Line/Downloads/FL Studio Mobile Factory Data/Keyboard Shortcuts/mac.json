{
    "modifiers": ["ctrl", "shift", "alt", "cmd"],
    "actions": [
        { "key": "cmd+",                        "action": "fineTweak" },
        { "key": "cmd+",                        "action": "editorSelect" },
        { "key": "cmd+s",                       "action": "saveProject" },
        { "key": "cmd+z",                       "action": "undo" },
        { "key": "shift+cmd+z",                 "action": "redo" },
        { "key": "space",                       "action": "play" },
        { "key": "cmd+left",                    "action": "rewind" },
        { "key": "alt+r",                       "action": "armRecord" },
        { "key": "f8",                          "action": "showMainBrowser" },
        { "key": "f10",                         "action": "showMainSettings" },
        { "key": "cmd+,",                       "action": "showMainSettings" },
        { "key": "f6",                          "action": "showRack" },
        { "key": "f9",                          "action": "showMainMixer" },
        { "key": "shift+cmd+t",                 "action": "showTempo" },
        { "key": "cmd+k",                       "action": "showTransport" },
        { "key": "cmd+c",                       "action": "copy" },
        { "key": "cmd+v",                       "action": "paste" },
        { "key": "cmd+x",                       "action": "cut" },
        { "key": "cmd+a",                       "action": "selectAll" },
        { "key": "delete",                      "action": "delete" },
        { "key": "cmd+up",                      "action": "leaveFolder" },
        { "key": "cmd+=",                       "action": "increment" },
        { "key": "shift+cmd+=",                 "action": "fineIncrement" },
        { "key": "cmd+-",                       "action": "decrement" },
        { "key": "shift+cmd+-",                 "action": "fineDecrement" },
        { "key": "cmd+=",                       "action": "zoomInHorizontal" },
        { "key": "shift+cmd+=",                 "action": "zoomInVertical" },
        { "key": "cmd+-",                       "action": "zoomOutHorizontal" },
        { "key": "shift+cmd+-",                 "action": "zoomOutVertical" },
        { "key": "escape",                      "action": "close" },
        { "key": "enter",                       "action": "open" },
        { "key": "tab",                         "action": "focusNext" },
        { "key": "shift+tab",                   "action": "focusPrev" },
        { "key": "right",                       "action": "focusRight" },
        { "key": "left",                        "action": "focusLeft" },
        { "key": "up",                          "action": "focusUp" },
        { "key": "down",                        "action": "focusDown" }
    ]
}
